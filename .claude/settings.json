{
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/setup-path.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["metals"],
  "enableAllProjectMcpServers": true
}
