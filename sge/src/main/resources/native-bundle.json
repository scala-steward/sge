    },
    {
      "name": "freetype",
      "platforms": {
        "linux-x86_64":    { "flags": [] },
        "linux-aarch64":   { "flags": [] },
        "macos-x86_64":    { "flags": [] },
        "macos-aarch64":   { "flags": [] },
        "windows-x86_64":  { "flags": [] },
        "windows-aarch64": { "flags": [] }
