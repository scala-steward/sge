        "macos-x86_64":    { "flags": ["-framework", "CoreAudio", "-framework", "AudioToolbox"] },
        "macos-aarch64":   { "flags": ["-framework", "CoreAudio", "-framework", "AudioToolbox"] },
        "windows-x86_64":  { "flags": [] },
        "windows-aarch64": { "flags": [] }
