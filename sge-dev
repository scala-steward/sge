#!/bin/bash
# Bootstrap wrapper: builds sge-dev from source if needed, then runs it.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN="$SCRIPT_DIR/scripts/bin/sge-dev"
SRC="$SCRIPT_DIR/scripts/src"

if [ ! -f "$BIN" ]; then
  echo "Building sge-dev from source..." >&2
  mkdir -p "$(dirname "$BIN")"
  scala-cli --power package --native "$SRC/" -o "$BIN" -f --suppress-outdated-dependency-warning >&2
fi

exec "$BIN" "$@"
